      background: rgba(32,211,194,.12);
      border:1px solid rgba(32,211,194,.25);
      color: rgba(240,255,252,.92);
      border-radius: 999px;
      font-weight: 750;
      font-size: .82rem;
    }
    .project ul{margin: 10px 0 0; padding-left: 18px; color: var(--muted)}
    .project li{margin: 6px 0}

    /* Skills / Certs */
    .skills{grid-column: span 7}
    .certs{grid-column: span 5}
    .two-col{display:grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 10px}
    .kv{
      border-radius: 14px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      padding: 12px;
    }
    .kv b{display:block; margin-bottom: 4px}
    .kv span{color: var(--muted); font-size: .94rem}

    /* Education / Contact */
    .edu{grid-column: span 7}
    .contact{grid-column: span 5}
    .contact a.link{
      display:inline-flex; gap:10px; align-items:center;
      padding:10px 12px; border-radius: 12px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      margin-top: 10px;
      color: var(--muted);
    }
    .contact a.link:hover{color: var(--text); border-color: rgba(32,211,194,.30)}
    .footer{
      padding: 28px 0 40px;
      color: var(--muted);
      text-align:center;
      font-size:.93rem;
    }

    /* Mobile */
    @media (max-width: 920px){
      .hero-grid{grid-template-columns: 1fr}
      .about, .highlights, .skills, .certs, .edu, .contact{grid-column: span 12}
      .project{grid-column: span 12}
      nav ul{display:none}
      .menu-btn{display:inline-flex}
      .quick-stats{grid-template-columns: 1fr 1fr 1fr}
