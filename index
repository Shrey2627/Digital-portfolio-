      grid-template-columns: 170px 1fr;
      gap: 14px;
      padding: 14px 0;
      border-top: 1px solid rgba(255,255,255,.08);
    }
    .role:first-child{border-top:none; padding-top:0}
    .role .when{color: var(--faint); font-weight: 700; font-size: .92rem}
    .role .where b{display:block}
    .role .where span{color: var(--muted); font-size: .94rem}
    .role ul{margin: 8px 0 0; padding-left: 18px; color: var(--muted)}
    .role li{margin: 6px 0}

    /* Projects */
    .project{grid-column: span 6; position:relative; overflow:hidden}
    .project:before{
      content:"";
