      --text: rgba(255,255,255,.92);
      --muted: rgba(255,255,255,.70);
      --faint: rgba(255,255,255,.55);
      --border: rgba(255,255,255,.12);
      --teal: #20d3c2;
      --teal2:#32f0dc;
      --navy: #061a2e;
      --shadow: 0 18px 40px rgba(0,0,0,.35);
      --shadow2: 0 14px 26px rgba(0,0,0,.25);
      --radius: 18px;
      --radius2: 12px;
      --max: 1120px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      color:var(--text);
      background:
        radial-gradient(1200px 700px at 15% 10%, rgba(32,211,194,.18), transparent 55%),
        radial-gradient(900px 600px at 85% 15%, rgba(50,240,220,.10), transparent 55%),
        radial-gradient(1000px 600px at 50% 100%, rgba(32,211,194,.10), transparent 55%),
        linear-gradient(180deg, #06111f 0%, #050b13 60%, #04070c 100%);
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      line-height: 1.55;
      overflow-x:hidden;
    }

    a{color:inherit; text-decoration:none}
    .container{width:min(var(--max), calc(100% - 40px)); margin:0 auto}
    .pill{
      display:inline-flex; align-items:center; gap:10px;
      padding:10px 14px;
      border:1px solid var(--border);
      border-radius:999px;
      background:rgba(255,255,255,.04);
      backdrop-filter: blur(8px);
      box-shadow: 0 8px 22px rgba(0,0,0,.16);
      color:var(--muted);
      font-size:.92rem;
    }
    .pill .dot{width:8px; height:8px; border-radius:50%; background:var(--teal); box-shadow: 0 0 0 6px rgba(32,211,194,.12)}
    .btn{
      display:inline-flex; align-items:center; justify-content:center;
      gap:10px;
      padding:12px 16px;
      border-radius: 12px;
      border:1px solid var(--border);
      background: rgba(255,255,255,.06);
      color: var(--text);
      cursor:pointer;
      transition: transform .14s ease, background .14s ease, border-color .14s ease;
      font-weight: 600;
    }
    .btn:hover{transform: translateY(-2px); background: rgba(255,255,255,.09); border-color: rgba(32,211,194,.35)}
    .btn.primary{
      background: linear-gradient(135deg, rgba(32,211,194,.96), rgba(50,240,220,.70));
      color:#021017;
      border-color: rgba(255,255,255,.18);
      box-shadow: 0 16px 32px rgba(32,211,194,.18);
    }
    .btn.primary:hover{background: linear-gradient(135deg, rgba(50,240,220,.98), rgba(32,211,194,.80))}
    .btn.ghost{background:transparent}
    .btn.small{padding:10px 12px; border-radius: 10px; font-size:.95rem}

    /* Header */
    header{
      position:sticky; top:0; z-index: 50;
      background: rgba(6, 17, 31, .55);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,.08);
    }
    .nav{
